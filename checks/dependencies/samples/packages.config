<?xml version="1.0" encoding="utf-8"?>
<packages>
  <!-- Common JSON handling library -->
  <package id="Newtonsoft.Json" version="13.0.3" targetFramework="net48" />

  <!-- Web API Framework -->
  <package id="Microsoft.AspNet.WebApi.Core" version="5.2.9" targetFramework="net48" />
  <package id="Microsoft.AspNet.WebApi.Client" version="5.2.9" targetFramework="net48" />
  <package id="Microsoft.AspNet.WebApi.WebHost" version="5.2.9" targetFramework="net48" />
  
  <!-- Data Access -->
  <package id="EntityFramework" version="6.4.4" targetFramework="net48" />
  <package id="Dapper" version="2.1.24" targetFramework="net48" />
  
  <!-- Testing Tools (marked as development dependencies) -->
  <package id="NUnit" version="3.13.3" targetFramework="net48" developmentDependency="true" />
  <package id="NUnit3TestAdapter" version="4.5.0" targetFramework="net48" developmentDependency="true" />
  <package id="Moq" version="4.18.4" targetFramework="net48" developmentDependency="true" />
  <package id="FluentAssertions" version="6.12.0" targetFramework="net48" developmentDependency="true" />
  
  <!-- Logging and Diagnostics -->
  <package id="log4net" version="2.0.15" targetFramework="net48" />
  <package id="Serilog" version="3.1.1" targetFramework="net48" />
  <package id="Serilog.Sinks.Console" version="5.0.0" targetFramework="net48" />
  
  <!-- Object Mapping -->
  <package id="AutoMapper" version="10.1.1" targetFramework="net48" />
  
  <!-- Dependency Injection -->
  <package id="Microsoft.Extensions.DependencyInjection" version="7.0.0" targetFramework="net48" />
  <package id="Autofac" version="7.1.0" targetFramework="net48" />
  
  <!-- Cross-platform targeting example -->
  <package id="Microsoft.Bcl.AsyncInterfaces" version="7.0.0" targetFramework="net48" />
  
  <!-- Example of package with allowedVersions constraint -->
  <package id="Microsoft.CSharp" version="4.7.0" targetFramework="net48" allowedVersions="[4.7.0]" />
  
  <!-- Example of package with specific version constraint -->
  <package id="System.Runtime.CompilerServices.Unsafe" version="6.0.0" targetFramework="net48" requireReinstallation="true" />
</packages>
