<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Default NuGet package source -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Example of a private feed -->
    <add key="CompanyFeed" value="https://pkgs.dev.azure.com/company/_packaging/CompanyFeed/nuget/v3/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <CompanyFeed>
      <add key="Username" value="%NUGET_USER%" />
      <add key="ClearTextPassword" value="%NUGET_PAT%" />
    </CompanyFeed>
  </packageSourceCredentials>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="CompanyFeed">
      <package pattern="Company.*" />
    </packageSource>
  </packageSourceMapping>
  <disabledPackageSources>
    <add key="Microsoft Visual Studio Offline Packages" value="true" />
  </disabledPackageSources>
  <config>
    <add key="globalPackagesFolder" value="%USERPROFILE%\.nuget\packages" />
    <add key="dependencyVersion" value="Highest" />
  </config>
</configuration> 